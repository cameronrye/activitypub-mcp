# ActivityPub MCP Server Configuration - DEVELOPMENT
# Copy this file to .env and customize for your environment
# For production deployment, use .env.production.example as a template

# ============================================================================
# ACTIVE CONFIGURATION
# These variables are currently used by the MCP server
# ============================================================================

# Environment
NODE_ENV=development

# MCP Server Configuration
MCP_SERVER_NAME=activitypub-mcp
MCP_SERVER_VERSION=3.0.0

# Logging Configuration
# Use 'debug' for development, 'info' for production
LOG_LEVEL=debug

# HTTP Configuration
USER_AGENT=ActivityPub-MCP-Client/3.0.0
REQUEST_TIMEOUT=15000

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000

# ============================================================================
# HTTP TRANSPORT (only used when MCP_TRANSPORT_MODE=http; stdio is default)
# ============================================================================

# MCP_TRANSPORT_MODE=stdio
# MCP_HTTP_PORT=3000
# MCP_HTTP_HOST=127.0.0.1

# REQUIRED if HTTP transport is enabled. v3 refuses to start without it.
# 32+ random characters recommended:
#   export MCP_HTTP_SECRET=$(node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
# MCP_HTTP_SECRET=

# CORS for HTTP transport. v3 default is empty (no origins allowed).
# Set explicitly for browser clients; "*" is allowed but discouraged.
# MCP_HTTP_CORS_ORIGINS=https://app.example.com

# DNS-rebinding protection allowlists for HTTP transport (comma-separated).
# Default localhost binding needs neither. If you bind to 0.0.0.0 / a public
# host, set MCP_HTTP_ALLOWED_HOSTS to the Host value(s) clients send, e.g.:
# MCP_HTTP_ALLOWED_HOSTS=mcp.example.com,mcp.example.com:3000
# MCP_HTTP_ALLOWED_ORIGINS=https://app.example.com

# ============================================================================
# AUTHENTICATED WRITE OPERATIONS (optional)
# ============================================================================

# v3: mutation tools (post, reply, delete, boost, follow, etc.) are NOT
# registered unless this is set to true. Default: false (read-only).
# ACTIVITYPUB_ENABLE_WRITES=false

# Misskey/Foundkey accounts are supported. The server auto-detects instance
# software via NodeInfo; no extra config is needed. The token must be a Misskey
# API access token with the required permissions.

# Multi-account configuration. v2 uses PIPE (|) as the field delimiter
# (v1 used colons; v2 will refuse to start if it sees the legacy form).
# Format: id|instance|token|username|label,id2|...
# ACTIVITYPUB_ACCOUNTS=work|fosstodon.org|TOKEN1|work_account|Work,personal|mastodon.social|TOKEN2|personal_account|Personal

# Single-account convenience (alternative to ACTIVITYPUB_ACCOUNTS):
# ACTIVITYPUB_DEFAULT_INSTANCE=mastodon.social
# ACTIVITYPUB_DEFAULT_TOKEN=
# ACTIVITYPUB_DEFAULT_USERNAME=

# Directory for the persisted credential store (accounts.json) created by
# `activitypub-mcp login`. Default: ${XDG_CONFIG_HOME:-~/.config}/activitypub-mcp
# ACTIVITYPUB_CONFIG_DIR=/path/to/config

# ============================================================================
# THREAD TRAVERSAL CAPS (applies to get-post-thread)
# ============================================================================

# MCP_THREAD_MAX_DEPTH=5
# MCP_THREAD_MAX_REPLIES=50
# MCP_THREAD_CROSS_ORIGIN_FETCH=false   # set to true to restore v1 fetch-everything

# ============================================================================
# INSTANCE SOFTWARE DETECTION (NodeInfo)
# ============================================================================

# Cache TTL for instance-software (NodeInfo) detection in milliseconds (default: 24h)
# MCP_INSTANCE_SOFTWARE_TTL_MS=86400000

# ============================================================================
# RESERVED FOR FUTURE USE
# These variables are defined but not currently used by the read-only client
# They are reserved for potential future features
# ============================================================================

# Server Configuration (for future local server features)
# PORT=8000
# HOST=localhost
# ACTIVITYPUB_BASE_URL=http://localhost:8000
# ACTIVITYPUB_DOMAIN=localhost:8000

# Default Instance (for examples and fallbacks)
# DEFAULT_INSTANCE=example.social

# Federation Configuration (for future write operations)
# FEDERATION_ENABLED=true
# FEDERATION_QUEUE_TYPE=memory
# FEDERATION_KV_TYPE=memory

# CORS Configuration (for future web interface)
# ENABLE_CORS=true
# CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:5173

# Development/Debug Configuration
# DEBUG=true
# DEBUG_MODE=true
# VERBOSE_LOGGING=true
# LOG_FORMAT=json
# LOG_FILE=logs/activitypub-mcp.log

# Database Configuration (for future persistence features)
# DATABASE_URL=sqlite:./data/activitypub.db
# DATABASE_URL=postgresql://user:password@localhost:5432/activitypub

# Redis Configuration (for future caching/queue features)
# REDIS_URL=redis://localhost:6379

# Security Keys (for future signing/authentication features)
# PRIVATE_KEY_PATH=./keys/private.pem
# PUBLIC_KEY_PATH=./keys/public.pem
# JWT_SECRET=your-jwt-secret-here

# External Services (for future notification features)
# SMTP_HOST=localhost
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# WEBHOOK_SECRET=your-webhook-secret

# Media Storage (for future media handling features)
# MEDIA_STORAGE_TYPE=local
# MEDIA_STORAGE_PATH=./media
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# Monitoring (for future production deployment)
# HEALTH_CHECK_PATH=/health
