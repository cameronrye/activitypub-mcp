# Production environment configuration for ActivityPub MCP Server (v3).
# Copy to .env and customise. Every variable here is read by src/config.ts
# (account vars are read by src/auth/account-manager.ts). Variables that
# earlier versions consumed but v3 does not — health-check probes, memory
# thresholds, performance metrics, and the /metrics endpoint — have been
# removed so this file reflects only what the server actually does.

NODE_ENV=production

# ─── MCP server identity ─────────────────────────────────────────────
MCP_SERVER_NAME=activitypub-mcp
MCP_SERVER_VERSION=3.0.0

# ─── Logging ─────────────────────────────────────────────────────────
# logtape level: debug | info | warning | error | fatal
LOG_LEVEL=info

# ─── HTTP transport (set MCP_TRANSPORT_MODE=http to enable) ──────────
# HTTP transport REFUSES to start without MCP_HTTP_SECRET. The secret must
# be at least 16 characters (32+ recommended); clients send it as a Bearer
# token on every /mcp request. Only /mcp is authenticated; /health returns
# {"status":"ok"} unauthenticated. There is no /metrics endpoint in v3.
#   export MCP_HTTP_SECRET=$(node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
MCP_TRANSPORT_MODE=stdio
# MCP_HTTP_PORT=3000
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_SECRET=replace-with-32-or-more-random-bytes
# MCP_HTTP_CORS_ENABLED=false
# MCP_HTTP_CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com
#
# DNS-rebinding protection allowlists. The default 127.0.0.1 bind needs
# neither. If you bind to 0.0.0.0 / a public host, set MCP_HTTP_ALLOWED_HOSTS
# to the Host value(s) clients send — otherwise the rebinding Host check is
# inert and access control rests solely on MCP_HTTP_SECRET (the server logs a
# warning on startup in that case).
# MCP_HTTP_ALLOWED_HOSTS=mcp.example.com,mcp.example.com:3000
# MCP_HTTP_ALLOWED_ORIGINS=https://app.example.com

# ─── Outbound HTTP client ────────────────────────────────────────────
USER_AGENT=ActivityPub-MCP-Client/3.0.0
REQUEST_TIMEOUT=10000
MAX_RESPONSE_SIZE=10485760
MAX_RETRIES=3
RETRY_BASE_DELAY=1000
RETRY_MAX_DELAY=30000

# ─── Cache ──────────────────────────────────────────────────────────
CACHE_TTL=300000
CACHE_MAX_SIZE=1000

# ─── Rate limiting ──────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_CLEANUP_INTERVAL=60000

# ─── Thread traversal caps (get-post-thread) ────────────────────────
MCP_THREAD_MAX_DEPTH=5
MCP_THREAD_MAX_REPLIES=50
MCP_THREAD_CROSS_ORIGIN_FETCH=false

# ─── Audit logging ──────────────────────────────────────────────────
AUDIT_LOG_ENABLED=true
AUDIT_LOG_MAX_ENTRIES=10000

# ─── Instance blocklist ─────────────────────────────────────────────
# Comma-separated list of domains; supports `*.example` wildcard.
INSTANCE_BLOCKING_ENABLED=true
# BLOCKED_INSTANCES=bad.example,*.spam.example

# ─── Dynamic instance discovery ─────────────────────────────────────
# Optional API token for instances.social (raises rate limits).
# INSTANCES_SOCIAL_TOKEN=
DYNAMIC_INSTANCE_CACHE_TTL=3600000
MAX_DYNAMIC_INSTANCES=100

# ─── Instance software detection (NodeInfo) ──────────────────────────
# Cache TTL for instance-software (NodeInfo) detection in ms (default: 24h)
# MCP_INSTANCE_SOFTWARE_TTL_MS=86400000

# ─── Authenticated write operations (optional) ──────────────────────
# v3 is READ-ONLY by default: mutation tools (post, reply, delete, boost,
# follow, block, etc.) are NOT registered unless this is set to true.
# ACTIVITYPUB_ENABLE_WRITES=true
#
# Configure at least one account to use authenticated tools. The simplest
# path is `activitypub-mcp login <instance>` (add --write to provision a
# write-capable token; otherwise the stored token is read-only). You can also
# supply accounts via env:
#
# Single-account form:
# ACTIVITYPUB_DEFAULT_INSTANCE=mastodon.social
# ACTIVITYPUB_DEFAULT_TOKEN=your-oauth-access-token
# ACTIVITYPUB_DEFAULT_USERNAME=youruser
#
# Multi-account form (pipe-delimited; the colon-delimited v1 form is rejected):
# ACTIVITYPUB_ACCOUNTS=id1|instance1|token1|username1|label1,id2|instance2|token2|username2|label2
#
# Directory for the persisted credential store (accounts.json) created by
# `activitypub-mcp login`. Default: ${XDG_CONFIG_HOME:-~/.config}/activitypub-mcp
# ACTIVITYPUB_CONFIG_DIR=/path/to/config
