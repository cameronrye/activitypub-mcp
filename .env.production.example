# Production environment configuration for ActivityPub MCP Server (v2).
# Copy to .env and customise. Every variable here is read by src/config.ts
# (the v1 production example referenced a number of env vars that v2
# does not consume — they've been removed here so this file reflects
# only what the server actually does).

NODE_ENV=production

# ─── MCP server identity ─────────────────────────────────────────────
MCP_SERVER_NAME=activitypub-mcp
MCP_SERVER_VERSION=2.0.0

# ─── Logging ─────────────────────────────────────────────────────────
# logtape level: trace | debug | info | warning | error | fatal
LOG_LEVEL=info

# ─── HTTP transport (set MCP_TRANSPORT_MODE=http to enable) ──────────
# In v2, HTTP transport REFUSES to start without MCP_HTTP_SECRET. The
# secret must be 32+ random characters; clients send it as a Bearer
# token on every /mcp and /metrics request. /health stays unauthenticated.
MCP_TRANSPORT_MODE=stdio
# MCP_HTTP_PORT=3000
# MCP_HTTP_HOST=127.0.0.1
# MCP_HTTP_SECRET=replace-with-32-or-more-random-bytes
# MCP_HTTP_CORS_ENABLED=false
# MCP_HTTP_CORS_ORIGINS=https://yourdomain.com,https://api.yourdomain.com

# ─── Outbound HTTP client ────────────────────────────────────────────
USER_AGENT=ActivityPub-MCP-Client/2.0.0
REQUEST_TIMEOUT=10000
MAX_RESPONSE_SIZE=10485760
MAX_RETRIES=3
RETRY_BASE_DELAY=1000
RETRY_MAX_DELAY=30000

# ─── Cache ──────────────────────────────────────────────────────────
CACHE_TTL=300000
CACHE_MAX_SIZE=1000

# ─── Rate limiting ──────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_CLEANUP_INTERVAL=60000

# ─── Health checks ──────────────────────────────────────────────────
HEALTH_CHECK_TIMEOUT=5000
HEALTH_CHECK_URL=https://mastodon.social/.well-known/nodeinfo
HEALTH_CHECK_EXTERNAL_PROBE=true
MEMORY_WARN_THRESHOLD_MB=500
MEMORY_WARN_THRESHOLD_PERCENT=80

# ─── Thread traversal caps (get-post-thread) ────────────────────────
MCP_THREAD_MAX_DEPTH=5
MCP_THREAD_MAX_REPLIES=50
MCP_THREAD_CROSS_ORIGIN_FETCH=false

# ─── Audit logging ──────────────────────────────────────────────────
AUDIT_LOG_ENABLED=true
AUDIT_LOG_MAX_ENTRIES=10000

# ─── Instance blocklist ─────────────────────────────────────────────
# Comma-separated list of domains; supports `*.example` wildcard.
INSTANCE_BLOCKING_ENABLED=true
# BLOCKED_INSTANCES=bad.example,*.spam.example

# ─── Dynamic instance discovery ─────────────────────────────────────
# Optional API token for instances.social (raises rate limits).
# INSTANCES_SOCIAL_TOKEN=
DYNAMIC_INSTANCE_CACHE_TTL=3600000
MAX_DYNAMIC_INSTANCES=100

# ─── Instance software detection (NodeInfo) ──────────────────────────
# Cache TTL for instance-software (NodeInfo) detection in milliseconds (default: 24h)
# MCP_INSTANCE_SOFTWARE_TTL_MS=86400000

# ─── Performance metrics (off by default) ───────────────────────────
# METRICS_ENABLED=true
# METRICS_INTERVAL=60000
# MAX_REQUEST_HISTORY=1000

# ─── Authenticated write operations (optional) ──────────────────────
# To enable post/follow/etc. tools, configure at least one account.
# Single-account form:
# ACTIVITYPUB_DEFAULT_INSTANCE=mastodon.social
# ACTIVITYPUB_DEFAULT_TOKEN=your-oauth-access-token
# ACTIVITYPUB_DEFAULT_USERNAME=youruser
#
# Multi-account form (pipe-delimited; v2 changed from colon to avoid
# conflict with colons in tokens):
# ACTIVITYPUB_ACCOUNTS=id1|instance1|token1|username1|label1,id2|instance2|token2|username2|label2
#
# Directory for the persisted credential store (accounts.json) created by
# `activitypub-mcp login`. Default: ${XDG_CONFIG_HOME:-~/.config}/activitypub-mcp
# ACTIVITYPUB_CONFIG_DIR=/path/to/config
