{
  "name": "activitypub-mcp",
  "version": "3.1.4",
  "description": "Model Context Protocol (MCP) server for the Fediverse — let Claude and other LLMs explore and post to Mastodon, Misskey, and Pleroma. Read-only by default.",
  "mcpName": "io.github.cameronrye/activitypub-mcp",
  "main": "dist/mcp-main.js",
  "bin": {
    "activitypub-mcp": "dist/mcp-main.js"
  },
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "MIGRATION-v2.md",
    "MIGRATION-v3.md"
  ],
  "keywords": [
    "activitypub",
    "mcp",
    "fediverse",
    "mastodon",
    "misskey",
    "pleroma",
    "webfinger",
    "activitystreams",
    "llm",
    "ai",
    "model-context-protocol",
    "claude",
    "social-media",
    "decentralized"
  ],
  "author": "Cameron Rye <c@meron.io>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cameronrye/activitypub-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/cameronrye/activitypub-mcp/issues"
  },
  "homepage": "https://github.com/cameronrye/activitypub-mcp#readme",
  "dependencies": {
    "@logtape/logtape": "^2.0.2",
    "@modelcontextprotocol/sdk": "^1.18.1",
    "undici": "^7.26.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^6.0.3",
    "@astrojs/sitemap": "^3.6.0",
    "@biomejs/biome": "^2.2.4",
    "@dotenvx/dotenvx": "^1.51.1",
    "@fontsource/bricolage-grotesque": "^5.2.10",
    "@fontsource/hanken-grotesk": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^4.0.18",
    "astro": "^6.4.5",
    "cross-env": "^10.0.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "npm-run-all2": "^8.0.4",
    "pagefind": "^1.4.0",
    "rimraf": "^6.0.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "scripts": {
    "dev": "dotenvx run -- tsx watch ./src/mcp-main.ts",
    "prod": "dotenvx run -- node --import tsx ./src/mcp-main.ts",
    "mcp": "tsx ./src/mcp-main.ts",
    "mcp:dev": "tsx watch ./src/mcp-main.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:integration": "vitest run --config vitest.config.integration.ts",
    "test:all": "vitest run && vitest run --config vitest.config.integration.ts",
    "test:coverage": "vitest run --coverage",
    "coverage": "vitest run --coverage",
    "lint": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" biome check .",
    "lint:fix": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" biome check --write .",
    "validate:biome": "node scripts/validate-biome-config.js",
    "validate:version": "node scripts/check-version.js",
    "precommit": "npm run validate:biome && npm run lint",
    "format": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" biome format --write .",
    "format:check": "cross-env NODE_OPTIONS=\"--max-old-space-size=4096\" biome ci .",
    "audit:prod": "npm audit --omit=dev --audit-level=moderate",
    "setup": "node scripts/run-platform.js setup",
    "setup:unix": "bash scripts/setup.sh",
    "setup:windows": "powershell -ExecutionPolicy Bypass -File scripts/setup.ps1",
    "install:claude": "node scripts/install.js --client=claude",
    "install:cursor": "node scripts/install.js --client=cursor",
    "install:shell": "node scripts/run-platform.js install",
    "install:shell:unix": "bash scripts/install.sh",
    "install:shell:windows": "powershell -ExecutionPolicy Bypass -File scripts/install.ps1",
    "uninstall": "node scripts/install.js uninstall",
    "build": "tsc",
    "build:site": "node scripts/generate-registry-manifest.js && astro build && npx pagefind --site dist-site && node scripts/generate-search-data.js",
    "dev:site": "astro dev",
    "preview:site": "astro preview",
    "generate:og-image": "node scripts/generate-og-image.js",
    "generate:favicons": "node scripts/generate-favicons.js",
    "check": "astro check",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "prepublishOnly": "run-s clean validate:version typecheck lint build"
  }
}
